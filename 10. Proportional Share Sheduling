#include <stdio.h>

int main() {
    int n, i, tq;
    int bt[10], wt[10], rt[10];
    int total_weight = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++) {
        printf("P%d Burst Time: ", i+1);
        scanf("%d", &bt[i]);

        printf("P%d Weight: ", i+1);
        scanf("%d", &wt[i]);

        rt[i] = bt[i];
        total_weight += wt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    printf("\nExecution:\n");

    while (total_weight > 0) {
        for (i = 0; i < n; i++) {
            if (rt[i] > 0) {
                int slice = (wt[i] * tq) / total_weight;
                if (slice <= 0) slice = 1;

                printf("P%d runs for %d units\n", i+1, slice);

                rt[i] -= slice;

                if (rt[i] <= 0) {
                    printf("P%d completed\n", i+1);
                    total_weight -= wt[i];
                }
            }
        }
    }

    return 0;
}
